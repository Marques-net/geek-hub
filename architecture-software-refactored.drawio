  <diagram id="geek-hub-architecture" name="Geek Hub">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="2" value="Usuarios / Browsers" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="90" y="30" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="3" value="Portal Web&#xa;Responsabilidade: login Google, sessao do usuario, menu principal e catalogo de jogos." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="70" y="120" width="260" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="4" value="Login Service&#xa;Responsabilidade: registrar login Google, telemetria do dispositivo e readiness da autenticacao." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="70" y="290" width="260" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="5" value="MongoDB Login Events&#xa;Responsabilidade: armazenar perfil basico, user agent e contexto do login." style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="90" y="470" width="220" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="6" value="Games Web&#xa;Responsabilidade: host dos jogos e roteamento por slug, por exemplo /games/chess e /games/tictactoe." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="410" y="120" width="300" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="7" value="Chess UI Module&#xa;Responsabilidade: lobby, tabuleiro, chat e envio de acoes do xadrez." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="410" y="290" width="300" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="8" value="TicTacToe UI Module&#xa;Responsabilidade: lobby, tabuleiro, chat e envio de acoes do jogo da velha." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="410" y="450" width="300" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="9" value="Shared Frontend Room SDK&#xa;Responsabilidade: sessao da sala, Socket.IO, WebRTC, chat, storage local e componentes reutilizaveis." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="410" y="620" width="300" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="10" value="Realtime Gateway&#xa;Responsabilidade: API publica /api e /socket.io, presenca, chat, WebRTC, metricas e roteamento para o core." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="810" y="250" width="320" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="11" value="Match Core Registry&#xa;Responsabilidade: ciclo de vida da sala, relogio, snapshots, Redis e despacho por tipo de jogo." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1220" y="250" width="320" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="12" value="Chess Runtime Adapter&#xa;Responsabilidade: validar jogadas, aplicar regras do xadrez, produzir snapshots e integrar bot do xadrez." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1220" y="440" width="320" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="13" value="TicTacToe Runtime Adapter&#xa;Responsabilidade: aplicar regras do jogo da velha, snapshots, empate, vitoria e bot." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1220" y="600" width="320" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="14" value="Future Game Runtimes&#xa;Responsabilidade: adicionar damas, lig-4 e outros sem recriar a plataforma." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1220" y="760" width="320" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="15" value="Bot Engine&#xa;Responsabilidade: estrategias de treino por jogo expostas via gRPC/protobuf." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1640" y="250" width="280" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="16" value="Chess Easy Strategy&#xa;Responsabilidade: selecionar acao simples e emitir dicas de treino para o xadrez." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1640" y="440" width="280" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="17" value="TicTacToe Easy Strategy&#xa;Responsabilidade: vitoria imediata, bloqueio, centro, cantos e laterais." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1640" y="600" width="280" height="100" as="geometry"/>
