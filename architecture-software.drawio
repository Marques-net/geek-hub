<mxfile host="app.diagrams.net" modified="2026-04-13T12:00:00.000Z" agent="Codex" version="24.7.17">
  <diagram id="geek-hub-architecture" name="Geek Hub">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="2" value="Portal Web&#xa;Responsabilidade: login Google, sessão do usuário, menu principal e catálogo de jogos." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="250" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="3" value="Games Web&#xa;Responsabilidade: host de jogos e navegação por rota, por exemplo /games/chess." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="250" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="4" value="Chess UI Module&#xa;Responsabilidade: lobby, tabuleiro, chat da sala e envio de ações do xadrez." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="400" width="250" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="5" value="Shared Frontend Room SDK&#xa;Responsabilidade: sessão da sala, Socket.IO, WebRTC signaling, chat e componentes reutilizáveis." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="40" y="560" width="250" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="6" value="Realtime Gateway&#xa;Responsabilidade: API pública /api e /socket.io, presença, chat, WebRTC signaling, métricas e roteamento para o core." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="400" y="200" width="300" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="7" value="Match Core&#xa;Responsabilidade: ciclo de vida de sala, relógio, snapshots, persistência e despacho por tipo de jogo." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="800" y="200" width="300" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="8" value="Chess Runtime Adapter&#xa;Responsabilidade: validar jogadas, aplicar regras do xadrez, produzir snapshots e integrar bot do xadrez." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="800" y="400" width="300" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="9" value="Future Game Adapters&#xa;Responsabilidade: implementar regras específicas de damas, lig-4 e outros sem recriar a plataforma." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="800" y="560" width="300" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="10" value="Bot Engine&#xa;Responsabilidade: estratégias de treino por jogo, expostas via gRPC/protobuf." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1210" y="200" width="270" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="11" value="Chess Easy Strategy&#xa;Responsabilidade: selecionar ação simples e emitir dicas de treino para o xadrez." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1210" y="380" width="270" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="12" value="Redis&#xa;Responsabilidade: estado efêmero de salas, partidas, relógios e sessões." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1210" y="560" width="270" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="13" value="Observability Stack&#xa;Responsabilidade: métricas, logs e traces em Prometheus, Loki, Tempo e Grafana." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="400" y="560" width="300" height="110" as="geometry"/>
        </mxCell>
